<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="BranchListReport"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <!-- ================= Fields ================= -->

    <field name="id" class="java.lang.Long"/>
    <field name="branchName" class="java.lang.String"/>
    <field name="city" class="java.lang.String"/>
    <field name="managerName" class="java.lang.String"/>
    <field name="contactNo" class="java.lang.Integer"/>

    <!-- ================= Title ================= -->

    <title>
        <band height="55">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="46"
                    backcolor="#1565C0"
                    forecolor="#1565C0"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="4" width="555" height="38"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Branch List Report]]></text>
            </staticText>

        </band>
    </title>

    <!-- ================= Page Header ================= -->

    <pageHeader>
        <band height="18">

            <staticText>
                <reportElement x="0" y="0" width="277" height="18"
                    forecolor="#666666"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Online Result System]]></text>
            </staticText>

            <textField pattern="dd-MM-yyyy HH:mm">
                <reportElement x="277" y="0" width="278" height="18"
                    forecolor="#666666"/>
                <textElement textAlignment="Right"
                    verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>

        </band>
    </pageHeader>

    <!-- ================= Column Header ================= -->

    <columnHeader>
        <band height="26">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="26"
                    backcolor="#0D2137"
                    forecolor="#0D2137"/>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <staticText>
                <reportElement x="0" y="0" width="25" height="26"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[#]]></text>
            </staticText>

            <staticText>
                <reportElement x="25" y="0" width="40" height="26"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[ID]]></text>
            </staticText>

            <staticText>
                <reportElement x="65" y="0" width="140" height="26"
                    forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Branch Name]]></text>
            </staticText>

            <staticText>
                <reportElement x="205" y="0" width="100" height="26"
                    forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[City]]></text>
            </staticText>

            <staticText>
                <reportElement x="305" y="0" width="150" height="26"
                    forecolor="#FFFFFF"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Manager Name]]></text>
            </staticText>

            <staticText>
                <reportElement x="455" y="0" width="100" height="26"
                    forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <text><![CDATA[Contact No]]></text>
            </staticText>

        </band>
    </columnHeader>

    <!-- ================= Detail ================= -->

    <detail>
        <band height="22">

            <rectangle>
                <reportElement x="0" y="0" width="555" height="22"
                    backcolor="#EEF2F7">
                    <printWhenExpression><![CDATA[$V{REPORT_COUNT}%2==0]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="0.0"/>
                </graphicElement>
            </rectangle>

            <textField>
                <reportElement x="0" y="0" width="25" height="22"
                    forecolor="#888888"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$V{REPORT_COUNT}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="25" y="0" width="40" height="22"
                    forecolor="#888888"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{id}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="65" y="0" width="140" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{branchName}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="205" y="0" width="100" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{city}]]></textFieldExpression>
            </textField>

            <textField isBlankWhenNull="true">
                <reportElement x="305" y="0" width="150" height="22"/>
                <textElement verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{managerName}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="455" y="0" width="100" height="22"/>
                <textElement textAlignment="Center"
                    verticalAlignment="Middle">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{contactNo}]]></textFieldExpression>
            </textField>

        </band>
    </detail>

    <!-- ================= Footer ================= -->

    <pageFooter>
        <band height="20">

            <line>
                <reportElement x="0" y="0" width="555" height="1"
                    forecolor="#CCCCCC"/>
            </line>

            <staticText>
                <reportElement x="0" y="3" width="277" height="16"
                    forecolor="#888888"/>
                <textElement>
                    <font size="8"/>
                </textElement>
                <text><![CDATA[Online Result System - Branch List Report]]></text>
            </staticText>

            <textField>
                <reportElement x="277" y="3" width="278" height="16"
                    forecolor="#888888"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>

        </band>
    </pageFooter>

    <!-- ================= Summary ================= -->

    <summary>
        <band height="30">

            <line>
                <reportElement x="0" y="4" width="555" height="1"
                    forecolor="#CCCCCC"/>
            </line>

            <textField>
                <reportElement x="0" y="10" width="300" height="18"
                    forecolor="#1565C0"/>
                <textElement>
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Total Branches: " + $V{REPORT_COUNT}]]></textFieldExpression>
            </textField>

        </band>
    </summary>

</jasperReport>